# --- Thesis Specific Whitelisting ---

# Ignore everything by default (except root files like .gitignore, which git handles)
# Wait, ignoring * ignores everything, including .gitignore, README.md, etc.
# We will explicitly ignore what we don't want.

# Folders to ignore
siuethesis/
MDPI___A_Comparative_Analysis_of_Implicit_Bias_and_Logical_Inconsistency_in_General_Purpose_and_Code_Specialized_Large_Language_Models/
reports/
docs/
src/*
data/*
.github/

# Files to ignore
tmp_output*.txt
abstract.md
auto_canonical_map.json
project_log.md
pyproject.toml
uv.lock

# WHITELIST CORE DATA
!data/dataset/
data/dataset/*
!data/dataset/prompts_old.jsonl
!data/dataset/prompts_unified_new.jsonl

!data/generated_functions_grok/
!data/generated_functions_unified_new/
!data/generated_functions_old/

# WHITELIST CORE SOURCE CODE
!src/generate_unified_dataset.py
!src/generate_functions.py
!src/generate_functions_grok.py
!src/run_audit_dynamic.py
!src/run_audit_dynamic_legacy.py
!src/analyze_results.py
!src/extract_protected_bias.py
